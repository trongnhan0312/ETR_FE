# ETR Aviation Training - Frontend Environment Variables Template
# Copy this file to '.env' and modify the values as needed.

# Application General Config
VITE_APP_TITLE="ETR Aviation Training Portal"
VITE_APP_ENV="development"

# API Service URL (Backend Endpoint)
VITE_API_URL="http://localhost:8080/api/v1"

# Other configuration (e.g., Timeout in milliseconds)
VITE_API_TIMEOUT=10000
